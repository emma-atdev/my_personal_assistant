# AI API
OPENAI_API_KEY=sk-...

# 검색
TAVILY_API_KEY=tvly-...       # https://tavily.com (무료 1,000회/월)

# DB - 로컬 개발 시 비워두기 (SQLite 자동 사용)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# 로컬 MCP 서버
# dev:  http://localhost:8002
# prod: https://<ngrok-domain>.ngrok-free.dev
MCP_SERVER_URL=http://localhost:8002
MCP_AUTH_TOKEN=your-secret-token

# GitHub
GITHUB_TOKEN=ghp_...   # Settings → Developer settings → Personal access tokens

# Google Calendar (OAuth 2.0)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
GOOGLE_REFRESH_TOKEN=  # scripts/get_google_token.py 실행 후 발급

# Notion
NOTION_API_KEY=secret_...          # notion.so/my-integrations → New integration
NOTION_CHANGELOG_PAGE_ID=          # CHANGELOG 기록할 페이지 ID (선택)

# 앱 설정
# development | production
ENV=development
PORT=8000
